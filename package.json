{
  "name": "game-shelf",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types"
  },
  "devDependencies": {
    "prettier": "3.8.1",
    "turbo": "2.9.3",
    "typescript": "5.9.2"
  },
  "pnpm": {
    "overrides": {
      "lightningcss": "1.30.1"
    }
  },
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=18"
  }
}
